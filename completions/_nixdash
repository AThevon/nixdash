#compdef nixdash

_nixdash() {
  local -a commands
  commands=(
    'list:List installed packages'
    'search:Search & install packages'
    'shell:Temporary shell with packages'
    'add-flake:Add external flake input'
    'config:Configuration settings'
    'init:Setup wizard'
  )

  _arguments -C \
    '(-v --version)'{-v,--version}'[Show version]' \
    '(-h --help)'{-h,--help}'[Show help]' \
    '1:command:->command' \
    '*::arg:->args'

  case "$state" in
    command)
      _describe -t commands 'nixdash command' commands
      ;;
  esac
}

_nixdash "$@"
